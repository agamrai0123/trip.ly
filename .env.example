# WanderPlan Environment Configuration Template
# Copy this to .env and fill in your actual values

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL connection
POSTGRES_USER=wanderplan_user
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=wanderplan
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgres://wanderplan_user:your-secure-password@localhost:5432/wanderplan

# Database for tests
POSTGRES_TEST_DB=wanderplan_test

# ============================================================================
# KAFKA CONFIGURATION
# ============================================================================

KAFKA_BROKERS=localhost:9092
KAFKA_CONSUMER_GROUP=wanderplan-consumer-group
KAFKA_TOPICS=user.events,trip.events,notification.events

# ============================================================================
# REDIS CONFIGURATION (if used)
# ============================================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================================
# SERVICE PORTS
# ============================================================================

API_GATEWAY_PORT=8080
API_GATEWAY_HOST=0.0.0.0

AUTH_SERVICE_PORT=8081
AUTH_SERVICE_HOST=0.0.0.0

TRIP_SERVICE_PORT=8082
TRIP_SERVICE_HOST=0.0.0.0

USER_SERVICE_PORT=8083
USER_SERVICE_HOST=0.0.0.0

COLLABORATION_SERVICE_PORT=8084
COLLABORATION_SERVICE_HOST=0.0.0.0

NOTIFICATION_SERVICE_PORT=8085
NOTIFICATION_SERVICE_HOST=0.0.0.0

SEARCH_SERVICE_PORT=8086
SEARCH_SERVICE_HOST=0.0.0.0

# ============================================================================
# JWT & AUTHENTICATION
# ============================================================================

# JWT Secret (use a long, random string in production)
JWT_SECRET=your-very-secure-jwt-secret-key-at-least-32-characters
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# OAuth Configuration (Google & GitHub)
OAUTH_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
OAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTH_GITHUB_CLIENT_ID=your-github-client-id
OAUTH_GITHUB_CLIENT_SECRET=your-github-client-secret

# Callback URLs
OAUTH_REDIRECT_URL=http://localhost:5173/auth/callback
OAUTH_GOOGLE_REDIRECT_URL=http://localhost:5173/auth/google/callback
OAUTH_GITHUB_REDIRECT_URL=http://localhost:5173/auth/github/callback

# ============================================================================
# API CONFIGURATION
# ============================================================================

# Frontend
VITE_API_BASE_URL=http://localhost:8080
VITE_APP_NAME=WanderPlan
VITE_APP_VERSION=1.0.0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Request-ID

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

LOG_LEVEL=debug
LOG_FORMAT=json
LOG_OUTPUT=stdout
LOG_FILE_PATH=./logs/app.log
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=10
LOG_MAX_AGE=30

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================

# Prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_METRICS_PORT=9091

# Jaeger (distributed tracing)
JAEGER_ENABLED=false
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831
JAEGER_SAMPLER_TYPE=const
JAEGER_SAMPLER_PARAM=1

# Health Check
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=5s

# ============================================================================
# EMAIL CONFIGURATION (for notifications)
# ============================================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@wanderplan.local

EMAIL_VERIFICATION_ENABLED=true
EMAIL_NOTIFICATIONS_ENABLED=true

# ============================================================================
# SEARCH CONFIGURATION
# ============================================================================

# Elasticsearch (if used)
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX=wanderplan

# ============================================================================
# AWS/EXTERNAL SERVICES (if used)
# ============================================================================

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=wanderplan-bucket

# ============================================================================
# ENVIRONMENT
# ============================================================================

NODE_ENV=development
GO_ENV=development
ENVIRONMENT=development

# ============================================================================
# FEATURE FLAGS
# ============================================================================

FEATURE_DARK_MODE=true
FEATURE_OFFLINE_MODE=false
FEATURE_ADVANCED_SEARCH=true
FEATURE_COLLABORATION=true
FEATURE_REAL_TIME_NOTIFICATIONS=true

# ============================================================================
# TESTING
# ============================================================================

TEST_ENABLED=true
TEST_DATABASE_URL=postgres://wanderplan_user:your-secure-password@localhost:5432/wanderplan_test
TEST_KAFKA_BROKERS=localhost:9092
COVERAGE_THRESHOLD=80

# ============================================================================
# DEPLOYMENT
# ============================================================================

DEPLOYMENT_ENV=local
DEPLOYMENT_REGION=local
DEPLOYMENT_VERSION=dev

# ============================================================================
# SECURITY
# ============================================================================

# HTTPS
HTTPS_ENABLED=false
TLS_CERT_PATH=./certs/server.crt
TLS_KEY_PATH=./certs/server.key

# API Key (for service-to-service communication)
API_KEY=your-secure-api-key
API_KEY_HEADER=X-API-Key

# Password Requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL_CHARS=true

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

APP_NAME=WanderPlan
APP_VERSION=1.0.0
APP_DESCRIPTION=AI-powered travel itinerary planning platform

# Max file upload size (in MB)
MAX_UPLOAD_SIZE=10

# Max request body size (in MB)
MAX_REQUEST_SIZE=5

# Session timeout (in minutes)
SESSION_TIMEOUT=30

# ============================================================================
# DEVELOPMENT SETTINGS (ONLY IN DEVELOPMENT)
# ============================================================================

# Enable CORS debugging
DEBUG_CORS=false

# Enable request logging
DEBUG_REQUESTS=false

# Enable SQL query logging
DEBUG_SQL=false

# Hot reload
HOT_RELOAD_ENABLED=true

# Mock data
MOCK_DATA_ENABLED=false

# ============================================================================
# CI/CD SETTINGS
# ============================================================================

CI_ENABLED=false
CI_PROVIDER=github-actions
CI_BUILD_NUMBER=
CI_BUILD_URL=
CI_BRANCH=
CI_COMMIT_SHA=

# ============================================================================
# NOTES
# ============================================================================

# 1. Never commit .env to git repository
# 2. Use .env.local for local overrides (also in .gitignore)
# 3. For production, use environment variables, not .env file
# 4. Keep .env.example updated with all variables
# 5. Mark sensitive values with [SENSITIVE] comment
# 6. Use strong random values for secrets
# 7. Rotate secrets regularly
