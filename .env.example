# WanderPlan — Root .env.example
# Copy to .env and fill in real values. Never commit .env.

# ─── Database (shared by all services) ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wanderplan
DB_USER=postgres
DB_PASSWORD=changeme
DB_SSL_MODE=disable

# ─── Kafka ─────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ─── JWT (RS256) ─────────────────────────────────────────────────────────
# Base64-encoded PEM. Generate with: openssl genrsa 2048 | base64 -w0
JWT_PRIVATE_KEY=<base64-encoded-rsa-private-key-pem>
JWT_PUBLIC_KEY=<base64-encoded-rsa-public-key-pem>

# ─── OAuth providers ───────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8081/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:8081/auth/github/callback

# ─── Frontend ──────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:5173

# ─── External APIs ─────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=

# ─── Service ports ─────────────────────────────────────────────────────────
# api-gateway
API_GATEWAY_PORT=8080

# auth-service
AUTH_SERVICE_PORT=8081
AUTH_SERVICE_GRPC_PORT=9081

# trip-service
TRIP_SERVICE_PORT=8082
TRIP_SERVICE_GRPC_PORT=9082

# user-service
USER_SERVICE_PORT=8083
USER_SERVICE_GRPC_PORT=9083

# collaboration-service
COLLAB_SERVICE_PORT=8084

# notification-service
NOTIF_SERVICE_PORT=8085
KAFKA_CONSUMER_GROUP=wanderplan-notifications

# search-service
SEARCH_SERVICE_PORT=8086
PLACES_CACHE_TTL_HOURS=24

# ─── Service-to-service addresses (used by api-gateway and user-service) ───
AUTH_SERVICE_GRPC_ADDR=localhost:9081
AUTH_SERVICE_ADDR=localhost:8081
TRIP_SERVICE_ADDR=localhost:8082
TRIP_SERVICE_GRPC_ADDR=localhost:9082
USER_SERVICE_ADDR=localhost:8083
COLLAB_SERVICE_ADDR=localhost:8084
NOTIF_SERVICE_ADDR=localhost:8085
SEARCH_SERVICE_ADDR=localhost:8086

# ─── Observability ─────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173
RATE_LIMIT_RPS=1000
RATE_LIMIT_BURST=2000
