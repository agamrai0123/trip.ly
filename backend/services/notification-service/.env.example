# notification-service — .env.example
# Copy to .env. Never commit .env.

PORT=8085

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wanderplan
DB_USER=postgres
DB_PASSWORD=changeme
DB_SSL_MODE=disable

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CONSUMER_GROUP=wanderplan-notifications

# Rate limiting
RATE_LIMIT_RPS=1000
RATE_LIMIT_BURST=2000
