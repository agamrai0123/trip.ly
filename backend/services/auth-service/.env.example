# auth-service — .env.example
# Copy to .env. Never commit .env.

PORT=8081
GRPC_PORT=9081

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wanderplan
DB_USER=postgres
DB_PASSWORD=changeme
DB_SSL_MODE=disable

# Kafka
KAFKA_BROKERS=localhost:9092

# JWT (RS256) — Base64-encoded PEM
JWT_PRIVATE_KEY=<base64-encoded-rsa-private-key-pem>
JWT_PUBLIC_KEY=<base64-encoded-rsa-public-key-pem>
JWT_EXPIRY=15m

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8081/auth/google/callback

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:8081/auth/github/callback

# Frontend (CORS + cookie redirect)
FRONTEND_URL=http://localhost:5173

# Rate limiting
RATE_LIMIT_RPS=1000
RATE_LIMIT_BURST=2000
