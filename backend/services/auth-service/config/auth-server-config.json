{
  "version": "1.0.0",
  "server_port": "8081",
  "grpc_port": "9081",
  "metric_port": 7082,
  "https_enabled": false,
  "logging": {
    "level": 1,
    "path": "./logs/auth-service.log",
    "max_size_mb": 100,
    "max_backups": 3,
    "max_age_days": 7
  },
  "database": {
    "host": "localhost",
    "port": 5432,
    "name": "wanderplan",
    "user": "postgres",
    "password": "",
    "ssl_mode": "disable",
    "schema": "wanderplan",
    "max_conns": 10,
    "min_conns": 2
  },
  "kafka": {
    "brokers": ["localhost:9092"],
    "topic_auth_events": "auth-events"
  },
  "oauth": {
    "google": {
      "client_id": "",
      "client_secret": "",
      "redirect_url": "http://localhost:8081/auth/google/callback"
    },
    "github": {
      "client_id": "",
      "client_secret": "",
      "redirect_url": "http://localhost:8081/auth/github/callback"
    }
  },
  "cors": {
    "allowed_origins": ["http://localhost:5173"]
  },
  "rate_limiting": {
    "rps": 20,
    "burst": 40
  },
  "cookie": {
    "domain": "localhost",
    "secure": false,
    "state_max_age_secs": 300
  }
}