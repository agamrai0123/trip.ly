# search-service — .env.example
# Copy to .env. Never commit .env.

PORT=8086

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wanderplan
DB_USER=postgres
DB_PASSWORD=changeme
DB_SSL_MODE=disable

# Google Places API
GOOGLE_PLACES_API_KEY=

# Cache TTL
PLACES_CACHE_TTL_HOURS=24

# Rate limiting
RATE_LIMIT_RPS=1000
RATE_LIMIT_BURST=2000
