{
  "title": "WanderPlan — search-service",
  "uid": "wanderplan-search-service",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Requests per Second",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"search-service\"}[1m]))",
          "legendFormat": "RPS"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 2,
      "title": "P50 / P95 / P99 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"search-service\"}[5m]))) * 1000",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"search-service\"}[5m]))) * 1000",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"search-service\"}[5m]))) * 1000",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 3,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "100 * sum(rate(http_requests_total{job=\"search-service\", status=~\"5..\"}[1m])) / sum(rate(http_requests_total{job=\"search-service\"}[1m]))",
          "legendFormat": "Error %"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 4,
      "title": "Goroutine Count",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "go_goroutines{job=\"search-service\"}",
          "legendFormat": "goroutines"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 } }
    },
    {
      "id": 5,
      "title": "Active DB Connections",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "db_pool_acquired_connections{job=\"search-service\"}",
          "legendFormat": "acquired"
        },
        {
          "expr": "db_pool_total_connections{job=\"search-service\"}",
          "legendFormat": "total"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 } }
    }
  ]
}
